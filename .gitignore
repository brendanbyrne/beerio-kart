node_modules/

# Docker bind-mount data (keep directories, ignore contents)
data/db/*
data/uploads/*
!data/db/.gitkeep
!data/uploads/.gitkeep

# Rust build artifacts
target/
.cargo/
# Coverage report from `just coverage-lcov` (written to the workspace root)
lcov.info

# Environment files
.env

# Assistant handoff files (ephemeral; live under .agents/handoffs/, only the README is tracked)
.agents/handoffs/*
!.agents/handoffs/README.md

# Assistant self-notes (ephemeral session state, live under .agents/memory/)
.agents/memory/*
!.agents/memory/.gitkeep

# Tool state (tokens, cookies)
tools/.state/

# Code review files
reviews/

# Static images
frontend/public/images/*

# Doc drafts: gitignored work-in-progress, with WIP_ checkpoint exception
docs/drafts/*
!docs/drafts/WIP_*.md
!docs/drafts/.gitkeep