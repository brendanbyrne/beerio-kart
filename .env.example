# Required: signing key for JWT auth tokens (use a long random string)
JWT_SECRET=

# Optional: JWT token lifetime in hours (default: 24)
# JWT_EXPIRY_HOURS=24

# Optional: UUID of the admin user (enables admin endpoints)
# ADMIN_USER_ID=

# Optional: database URL (default: sqlite:../data/beerio-kart.db?mode=rwc)
# DATABASE_URL=sqlite:../data/beerio-kart.db?mode=rwc

# Optional: log level filter (default: info)
# RUST_LOG=info

# Optional: directory for built frontend files (default: ../frontend/dist)
# STATIC_DIR=../frontend/dist

# Optional: directory for user-uploaded photos (default: ../uploads)
# UPLOAD_DIR=../uploads
